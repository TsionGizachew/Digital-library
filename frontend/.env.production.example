# Frontend Production Environment Variables
# Copy this to .env.production and update with your actual values

# Backend API URL (Railway/Render deployment URL)
REACT_APP_API_URL=https://your-app.up.railway.app/api/v1

# App Information
REACT_APP_NAME=Yeka Sub City Library
REACT_APP_VERSION=1.0.0

# Feature Flag
REACT_APP_ENABLE_SOCKET=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# Build Configuration
GENERATE_SOURCEMAP=false
